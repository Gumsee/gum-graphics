@PACKAGE_INIT@

#include("@CMAKE_INSTALL_FULL_LIBDIR@/cmake/@CMAKE_PROJECT_NAME@/@CMAKE_PROJECT_NAME@Targets.cmake")

check_required_components(@CMAKE_PROJECT_NAME@)

set(GUMGRAPHICS_INCLUDE_DIRS   "@CMAKE_INSTALL_FULL_INCLUDEDIR@/@CMAKE_PROJECT_NAME@" )
find_library(GUMGRAPHICS_LIBRARIES NAMES @CMAKE_PROJECT_NAME@
    PATHS
    "/usr/lib"
    "/usr/local/lib"
    "@CMAKE_INSTALL_FULL_LIBDIR@"
)

set(GUMGRAPHICS_FOUND TRUE)
if(NOT GUMGRAPHICS_LIBRARIES)
    set(GUMGRAPHICS_FOUND FALSE)
endif()
