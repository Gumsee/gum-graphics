@PACKAGE_INIT@

#include("@CMAKE_INSTALL_FULL_LIBDIR@/cmake/@PROJECT_NAME@/@PROJECT_NAME@Targets.cmake")

check_required_components(@PROJECT_NAME@)

set(GUMGRAPHICS_INCLUDE_DIRS   "@CMAKE_INSTALL_FULL_INCLUDEDIR@/@PROJECT_NAME@" )
find_library(GUMGRAPHICS_LIBRARIES NAMES @PROJECT_NAME@
    PATHS
    "/usr/lib"
    "/usr/local/lib"
    "@CMAKE_INSTALL_FULL_LIBDIR@"
)

set(GUMGRAPHICS_FOUND TRUE)
if(NOT GUMGRAPHICS_LIBRARIES)
    set(GUMGRAPHICS_FOUND FALSE)
endif()
